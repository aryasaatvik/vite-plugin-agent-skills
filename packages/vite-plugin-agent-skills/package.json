{
  "name": "vite-plugin-agent-skills",
  "version": "0.1.0",
  "description": "Import Agent Skills from SKILL.md files in Vite.",
  "keywords": [
    "agent-skills",
    "skills",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/aryasaatvik/vite-plugin-agent-skills#readme",
  "bugs": "https://github.com/aryasaatvik/vite-plugin-agent-skills/issues",
  "license": "MIT",
  "author": "Saatvik Arya",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aryasaatvik/vite-plugin-agent-skills.git",
    "directory": "packages/vite-plugin-agent-skills"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "type": "module",
  "types": "./dist/root.d.ts",
  "exports": {
    ".": {
      "types": "./dist/root.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.json --emitDeclarationOnly --noEmit false",
    "prepack": "bun run build",
    "package:smoke": "bun run build && npm pack --dry-run",
    "release": "bun run typecheck && bun run test && bun run package:smoke && npm publish",
    "dev": "tsdown --watch --ignore-watch .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/vite-plugin-agent-skills/tests"
  },
  "dependencies": {
    "@rolldown/pluginutils": "^1.0.1",
    "ignore": "^7.0.5",
    "js-yaml": "^5.2.0",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
