{
  "name": "vite-plugin-agent-skills-repo",
  "version": "0.0.0",
  "private": true,
  "description": "Bun monorepo for vite-plugin-agent-skills.",
  "license": "MIT",
  "author": "Arya Labs, Inc.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "clean": "rm -rf node_modules .turbo coverage packages/*/dist examples/*/dist"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.16.7",
    "turbo": "^2.9.18",
    "typescript": "7.0.1-rc",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "bun": ">=1.3.2",
    "node": ">=24.10.0"
  },
  "packageManager": "bun@1.3.14"
}
